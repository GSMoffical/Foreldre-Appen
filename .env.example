# Synka — required environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase project URL (found in Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose in frontend — RLS is your security layer)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Tankestrøm AI analysis service URL
# Points to the Flask/Vercel endpoint that processes school documents
VITE_TANKESTROM_ANALYZE_URL=https://your-tankestrom-service.vercel.app/api/analyze

# Optional: set to 'true' to enable verbose HTTP debug logging for Tankestrøm
# WARNING: never set this to 'true' in production — it logs API responses to the browser console
# VITE_DEBUG_SCHOOL_IMPORT=true

echo. >> .env.example && echo # Sentry error monitoring DSN (get from sentry.io dashboard) >> .env.example && echo VITE_SENTRY_DSN=your-sentry-dsn-here >> .env.example