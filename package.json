{
  "name": "parenting-calendar",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check:supabase-events-schema": "vitest run src/lib/__tests__/supabaseEventsSchema.integration.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "eval:tankestrom:soak": "node ./scripts/eval-tankestrom-soak.mjs",
    "eval:tankestrom": "node ./scripts/eval-tankestrom.mjs",
    "eval:tankestrom:duration": "vitest run src/lib/tankestromEval/__tests__/hostcupDurationInference.test.ts && vitest run src/lib/tankestromEval/__tests__/hostcupDurationInference.strict.test.ts",
    "eval:tankestrom:ci": "node ./scripts/eval-tankestrom.mjs --fixture=all --runs=5 --seed=42",
    "deploy:hostinger": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-hostinger.ps1",
    "deploy:hostinger:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-hostinger.ps1 -DryRun",
    "deploy:hostinger:test": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-hostinger.ps1 -SkipBuild -TestConnection",
    "deploy:hostinger:password": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-hostinger.ps1 -UsePasswordAuth",
    "deploy:hostinger:password:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-hostinger.ps1 -UsePasswordAuth -DryRun",
    "deploy:hostinger:test:password": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-hostinger.ps1 -SkipBuild -TestConnection -UsePasswordAuth",
    "verify:hostinger": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-hostinger.ps1"
  },
  "dependencies": {
    "@capacitor/camera": "^7.0.1",
    "@capacitor/cli": "^7.0.1",
    "@capacitor/core": "^7.0.1",
    "@capacitor/filesystem": "^7.0.1",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@sentry/react": "^10.57.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tabler/icons-react": "^3.44.0",
    "date-holidays": "^3.26.11",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^5.4.21",
    "vitest": "^4.1.0"
  }
}
